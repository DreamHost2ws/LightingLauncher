{
  "name": "ag-launcher",
  "version": "1.0.0",
  "description": "AG Launcher - Minecraft Launcher",
  "author": "DreamHost2ws",
  "license": "MIT",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },

  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3"
  },

  "build": {
    "appId": "com.aglauncher.app",
    "productName": "AG Launcher",

    "directories": {
      "output": "dist",
      "buildResources": "build"
    },

    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**"
    ],

    "asar": true,

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AG Launcher"
    }
  }
}
