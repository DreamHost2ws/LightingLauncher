<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgLauncher.Mobile.Pages.VersionsPage"
             Title="Versions"
             BackgroundColor="#1F1F1F">

    <VerticalStackLayout Padding="20" Spacing="10">
        <SearchBar Placeholder="Search versions..." BackgroundColor="#2A2A2A" TextColor="#F5F5F5"/>
        
        <CollectionView SelectionMode="Single">
            <CollectionView.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>✓ 1.20.1 (Latest)</x:String>
                    <x:String>○ 1.20</x:String>
                    <x:String>○ 1.19.3</x:String>
                    <x:String>○ 1.18.2</x:String>
                </x:Array>
            </CollectionView.ItemsSource>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#00D4FF" CornerRadius="8" Padding="15" Margin="0,5" Background="#2A2A2A">
                        <Label Text="{Binding .}" TextColor="#F5F5F5"/>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Install Version" Background="#00D4FF" TextColor="#1F1F1F" VerticalOptions="EndAndExpand"/>
    </VerticalStackLayout>
</ContentPage>
