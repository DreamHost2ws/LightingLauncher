<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgLauncher.Mobile.Pages.ModsPage"
             Title="Mods"
             BackgroundColor="#1F1F1F">

    <VerticalStackLayout Padding="20" Spacing="10">
        <Label Text="Installed Mods" FontSize="18" FontAttributes="Bold" TextColor="#F5F5F5"/>
        
        <CollectionView>
            <CollectionView.ItemsSource>
                <x:Array Type="{x:Type x:String}">
                    <x:String>Fabric Loader 0.14.21</x:String>
                    <x:String>Sodium 0.5.0</x:String>
                    <x:String>Lithium 0.11.0</x:String>
                    <x:String>Phosphor 0.8.0</x:String>
                </x:Array>
            </CollectionView.ItemsSource>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="#00D4FF" CornerRadius="8" Padding="15" Margin="0,5" Background="#2A2A2A">
                        <HorizontalStackLayout Spacing="15">
                            <Label Text="🧩" FontSize="24" VerticalOptions="Center"/>
                            <Label Text="{Binding .}" TextColor="#F5F5F5" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Add Mod" Background="#00D4FF" TextColor="#1F1F1F" VerticalOptions="EndAndExpand"/>
    </VerticalStackLayout>
</ContentPage>
