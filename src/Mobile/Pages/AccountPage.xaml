<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgLauncher.Mobile.Pages.AccountPage"
             Title="Account"
             BackgroundColor="#1F1F1F">

    <VerticalStackLayout Padding="20" Spacing="20">
        <Frame BorderColor="#00D4FF" CornerRadius="10" Padding="20" Background="#2A2A2A">
            <VerticalStackLayout Spacing="15">
                <Ellipse WidthRequest="80" HeightRequest="80" Fill="#00D4FF" HorizontalOptions="Center"/>
                <Label Text="No Account" FontSize="18" FontAttributes="Bold" TextColor="#F5F5F5" HorizontalTextAlignment="Center"/>
                <Label Text="Sign in with Microsoft or create an offline account" TextColor="#888888" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>
        </Frame>

        <Button Text="🔐 Login with Microsoft" Background="#00D4FF" TextColor="#1F1F1F" Padding="15"/>
        <Button Text="➕ Create Offline Account" Background="#00D4FF" TextColor="#1F1F1F" Padding="15"/>

        <Frame BorderColor="#00D4FF" CornerRadius="10" Padding="15" Background="#2A2A2A" Margin="0,20,0,0">
            <VerticalStackLayout Spacing="10">
                <Label Text="⚙️ Settings" FontSize="16" FontAttributes="Bold" TextColor="#F5F5F5"/>
                <Label Text="Performance Profile: Balanced" TextColor="#888888" FontSize="12"/>
                <Label Text="Cache Size: 2.3 GB" TextColor="#888888" FontSize="12"/>
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>
