<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AgLauncher.Mobile.Pages.HomePage"
             Title="Ag-Lancher"
             BackgroundColor="#1F1F1F">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <!-- Header -->
            <HorizontalStackLayout Spacing="10" Padding="0,20,0,0">
                <Label Text="🎮" FontSize="32"/>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Ag-Lancher" FontSize="24" FontAttributes="Bold" TextColor="#00D4FF"/>
                    <Label Text="Fast Minecraft Launcher" TextColor="#888888" FontSize="12"/>
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <!-- Account Card -->
            <Frame BorderColor="#00D4FF" CornerRadius="10" Padding="15" Background="#2A2A2A">
                <VerticalStackLayout Spacing="10">
                    <Label Text="👤 Account" FontSize="16" FontAttributes="Bold" TextColor="#F5F5F5"/>
                    <Label Text="Not logged in" TextColor="#888888"/>
                    <Button Text="Login" Background="#00D4FF" TextColor="#1F1F1F" Padding="10"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Quick Stats -->
            <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="10">
                <Frame BorderColor="#00D4FF" CornerRadius="8" Padding="10" Background="#2A2A2A">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="📦" FontSize="24"/>
                        <Label Text="Versions" FontSize="12" TextColor="#888888"/>
                        <Label Text="5" FontSize="20" FontAttributes="Bold" TextColor="#F5F5F5"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame BorderColor="#00D4FF" CornerRadius="8" Padding="10" Background="#2A2A2A" Grid.Column="1">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="🧩" FontSize="24"/>
                        <Label Text="Mods" FontSize="12" TextColor="#888888"/>
                        <Label Text="12" FontSize="20" FontAttributes="Bold" TextColor="#F5F5F5"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- Launch Button -->
            <Button Text="▶ LAUNCH GAME" Background="#00D4FF" TextColor="#1F1F1F" 
                    FontSize="18" FontAttributes="Bold" Padding="20,15" CornerRadius="8"/>

            <!-- Recent Activity -->
            <Frame BorderColor="#00D4FF" CornerRadius="10" Padding="15" Background="#2A2A2A">
                <VerticalStackLayout Spacing="10">
                    <Label Text="📊 Recent Activity" FontSize="14" FontAttributes="Bold" TextColor="#F5F5F5"/>
                    <Label Text="✓ Launched Minecraft 1.20.1" TextColor="#00D084"/>
                    <Label Text="✓ Cache optimized" TextColor="#00D084"/>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
