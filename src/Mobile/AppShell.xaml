<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AgLauncher.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Home"
            ContentTemplate="{DataTemplate Pages:HomePage}"
            Route="HomePage" />
        <ShellContent
            Title="Versions"
            ContentTemplate="{DataTemplate Pages:VersionsPage}"
            Route="VersionsPage" />
        <ShellContent
            Title="Mods"
            ContentTemplate="{DataTemplate Pages:ModsPage}"
            Route="ModsPage" />
        <ShellContent
            Title="Account"
            ContentTemplate="{DataTemplate Pages:AccountPage}"
            Route="AccountPage" />
    </TabBar>
</Shell>
